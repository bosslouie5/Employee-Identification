{
  "name": "employees-identification",
  "private": true,
  "version": "0.1.0",
  "homepage": "https://bosslouie5.github.io/Employee-Identification",
  "type": "module",
  "scripts": {
    "setup": "npm install && npm run server:install",
    "dev": "vite",
    "dev:server": "npm --prefix server start",
    "dev:full": "npx concurrently \"npm run dev:server\" \"npm run dev\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "npm run build && node server/server.js",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "postinstall": "cd server && npm install",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "framer-motion": "^11.0.0",
    "multer": "^2.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-qr-code": "^2.2.0",
    "react-easy-crop": "^6.0.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^8.2.0",
    "gh-pages": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  }
}
